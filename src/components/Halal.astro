---
import { type Locale, t } from "../i18n/ui";
import { SARAJEVO_MASJIDS, SARAJEVO_CENTER } from "../data/masjids";
export interface Props { lang: Locale }
const { lang } = Astro.props;
const s = t(lang);
const cities = ["Sarajevo", "Mostar", "Tuzla", "Zenica", "Banja Luka"];
const order: Array<keyof typeof s.halal.prayerNames> = ["Fajr", "Dhuhr", "Asr", "Maghrib", "Isha"];
---
<section id="halal" class="wrap" style="padding-block:56px;border-top:1px solid var(--rule)">
  <p class="eyebrow reveal">{s.halal.kicker}</p>
  <h2 class="section-title reveal" style="margin-top:10px">{s.halal.title}</h2>
  <p class="lead reveal" style="margin-top:8px">{s.halal.lead}</p>

  <div class="flex flex-wrap gap-2 reveal" style="margin-top:18px">
    {s.halal.filters.map((f, i) => (
      <span class="chip"><span style="color:var(--success);font-weight:800">{i === 0 ? "★" : "✓"}</span> {f}</span>
    ))}
  </div>

  <div class="bl-split reveal" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:24px">
    <!-- Prayer times -->
    <div class="card" style="padding:24px">
      <div class="flex items-center justify-between gap-3" style="flex-wrap:wrap">
        <h3 style="font-size:17px;font-weight:700">{s.halal.prayerTitle}</h3>
        <label style="font-size:13px;color:var(--ink-2);display:flex;align-items:center;gap:8px">
          {s.halal.prayerCityLabel}
          <select id="bl-city" style="font:inherit;font-size:13px;padding:6px 10px;border-radius:10px;border:1px solid var(--rule);background:var(--surface-2);color:var(--ink)">
            {cities.map((c) => <option value={c}>{c}</option>)}
          </select>
        </label>
      </div>
      <p id="bl-prayer-status" style="font-size:12.5px;color:var(--ink-3);margin-top:8px">{s.halal.prayerLoading}</p>
      <div id="bl-prayer-grid" style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-top:14px">
        {order.map((k) => (
          <div class="bl-ptime" data-prayer={k} style="text-align:center;background:var(--surface-2);border:1px solid var(--rule);border-radius:12px;padding:12px 6px">
            <div style="font-size:11px;color:var(--ink-3)">{s.halal.prayerNames[k]}</div>
            <div class="bl-pt" style="font-size:15px;font-weight:700;margin-top:4px">--:--</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Masjid map -->
    <div class="card" style="padding:14px">
      <div class="flex items-center justify-between gap-2" style="padding:6px 8px;flex-wrap:wrap">
        <h3 style="font-size:17px;font-weight:700">{s.halal.mapTitle}</h3>
        <button id="bl-locate" type="button" class="btn" style="padding:8px 14px;font-size:13px">{s.halal.locateBtn}</button>
      </div>
      <div id="bl-map" role="region" aria-label={s.halal.mapTitle} style="height:240px;border-radius:14px;overflow:hidden;margin-top:6px;background:var(--surface-2)"></div>
      <p style="font-size:12px;color:var(--ink-3);margin-top:10px;padding-inline:4px">{s.halal.mapNote}</p>
    </div>
  </div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script is:inline define:vars={{ masjids: SARAJEVO_MASJIDS, center: SARAJEVO_CENTER, labels: s.halal.prayerNames, errMsg: s.halal.prayerError, locating: s.halal.locating, locateLabel: s.halal.locateBtn, statusOkPrefix: s.halal.nextLabel, tomorrowLabel: s.halal.tomorrow }}>
  (function () {
    // ---------- Prayer times (Aladhan, free, no key) ----------
    var FALLBACK = { Fajr: "03:42", Dhuhr: "12:58", Asr: "16:54", Maghrib: "20:21", Isha: "22:11" };
    var order = ["Fajr", "Dhuhr", "Asr", "Maghrib", "Isha"];
    var statusEl = document.getElementById("bl-prayer-status");
    var citySel = document.getElementById("bl-city");

    function toMins(hhmm) { var p = String(hhmm).split(":"); return (+p[0]) * 60 + (+p[1]); }

    function paint(timings, live) {
      var now = new Date();
      var nowM = now.getHours() * 60 + now.getMinutes();
      var nextKey = null;
      for (var i = 0; i < order.length; i++) {
        if (toMins(timings[order[i]]) >= nowM) { nextKey = order[i]; break; }
      }
      var rolledOver = !nextKey; // after Isha -> tomorrow's Fajr
      if (!nextKey) nextKey = "Fajr";
      document.querySelectorAll(".bl-ptime").forEach(function (cell) {
        var k = cell.getAttribute("data-prayer");
        var v = (timings[k] || "--:--").slice(0, 5);
        cell.querySelector(".bl-pt").textContent = v;
        var on = k === nextKey;
        cell.style.background = on ? "var(--accent)" : "var(--surface-2)";
        cell.style.borderColor = on ? "var(--accent)" : "var(--rule)";
        cell.style.color = on ? "var(--accent-ink)" : "";
      });
      if (statusEl) {
        statusEl.textContent = (live ? "" : errMsg + "  ") + statusOkPrefix + ": " + (labels[nextKey] || nextKey) + " " + (timings[nextKey] || "").slice(0, 5) + (rolledOver ? " (" + tomorrowLabel + ")" : "");
        statusEl.style.color = "var(--ink-3)";
      }
    }

    function loadPrayer(city) {
      var url = "https://api.aladhan.com/v1/timingsByCity?city=" + encodeURIComponent(city) +
        "&country=Bosnia%20and%20Herzegovina&method=2";
      fetch(url).then(function (r) { return r.json(); }).then(function (d) {
        if (d && d.data && d.data.timings) paint(d.data.timings, true);
        else paint(FALLBACK, false);
      }).catch(function () { paint(FALLBACK, false); });
    }

    if (citySel) citySel.addEventListener("change", function () { loadPrayer(citySel.value); });
    loadPrayer(citySel ? citySel.value : "Sarajevo");

    // ---------- Masjid map (Leaflet + OSM, no key) ----------
    var mapEl = document.getElementById("bl-map");
    var map = null, layer = null;
    function ready(cb) {
      if (window.L) return cb();
      var tries = 0;
      var iv = setInterval(function () {
        if (window.L) { clearInterval(iv); cb(); }
        else if (++tries > 60) { clearInterval(iv); }
      }, 100);
    }
    // Escape untrusted text (Overpass mosque names) before it reaches
    // Leaflet bindPopup, which renders its argument as HTML.
    function esc(s) {
      return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;")
        .replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }
    function pin(m, label, isUser) {
      var color = isUser ? "#14b8a1" : "#C8A24B";
      var icon = window.L.divIcon({
        className: "",
        html: '<div style="width:16px;height:16px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);background:' + color + ';border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.5)"></div>',
        iconSize: [16, 16], iconAnchor: [8, 16],
      });
      var mk = window.L.marker([m.lat, m.lng], { icon: icon });
      if (label) mk.bindPopup(label);
      return mk;
    }
    ready(function () {
      if (!mapEl) return;
      map = window.L.map(mapEl, { scrollWheelZoom: false, attributionControl: true }).setView([center.lat, center.lng], 13);
      window.L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19, attribution: "&copy; OpenStreetMap",
      }).addTo(map);
      layer = window.L.layerGroup().addTo(map);
      masjids.forEach(function (m) { pin(m, esc(m.name + " - " + m.area)).addTo(layer); });
    });

    // ---------- "Near me" -> Overpass live masjids ----------
    var locateBtn = document.getElementById("bl-locate");
    if (locateBtn) locateBtn.addEventListener("click", function () {
      if (!navigator.geolocation) return;
      var orig = locateBtn.textContent; locateBtn.textContent = locating; locateBtn.disabled = true;
      navigator.geolocation.getCurrentPosition(function (pos) {
        var la = pos.coords.latitude, ln = pos.coords.longitude;
        ready(function () {
          if (!map) return;
          map.setView([la, ln], 14);
          layer.clearLayers();
          pin({ lat: la, lng: ln }, "You", true).addTo(layer);
          var q = "[out:json][timeout:20];(node[\"amenity\"=\"place_of_worship\"][\"religion\"=\"muslim\"](around:4000," + la + "," + ln + "););out 40;";
          fetch("https://overpass-api.de/api/interpreter", { method: "POST", body: q })
            .then(function (r) { return r.json(); })
            .then(function (d) {
              (d.elements || []).forEach(function (e) {
                var nm = (e.tags && (e.tags.name || e.tags["name:en"])) || "Masjid";
                pin({ lat: e.lat, lng: e.lon }, esc(nm)).addTo(layer);
              });
            }).catch(function () {});
          locateBtn.textContent = orig; locateBtn.disabled = false;
        });
      }, function () { locateBtn.textContent = orig; locateBtn.disabled = false; }, { timeout: 8000 });
    });
  })();
</script>

<style>
  @media (max-width: 820px) {
    #halal :global(.bl-split) { grid-template-columns: 1fr !important; }
  }
</style>
