---
import { type Locale, t } from "../i18n/ui";
export interface Props { lang: Locale }
const { lang } = Astro.props;
const s = t(lang);
const p = s.property;
---
<section id="property" class="wrap" style="padding-block:56px;border-top:1px solid var(--rule)">
  <div class="bl-prop reveal" style="display:grid;grid-template-columns:0.9fr 1.1fr;gap:24px;align-items:start">
    <div>
      <p class="eyebrow">{p.kicker}</p>
      <h2 class="section-title" style="margin-top:10px">{p.title}</h2>
      <p class="lead" style="margin-top:8px">{p.lead}</p>
      <div style="font-size:60px;margin-top:18px">&#127968;</div>
    </div>

    <div class="card" style="padding:26px">
      <form id="bl-prop-form" novalidate style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div style="grid-column:1 / -1">
          <label class="bl-plabel" for="bl-prop-budget">{p.fields.budget}</label>
          <select id="bl-prop-budget" name="budget" class="bl-pfield" required>
            <option value="">--</option>
            {p.fields.budgetOptions.map((o) => <option value={o}>{o}</option>)}
          </select>
        </div>
        <div>
          <label class="bl-plabel" for="bl-prop-purpose">{p.fields.purpose}</label>
          <select id="bl-prop-purpose" name="purpose" class="bl-pfield">
            {p.fields.purposeOptions.map((o) => <option value={o}>{o}</option>)}
          </select>
        </div>
        <div>
          <label class="bl-plabel" for="bl-prop-timeline">{p.fields.timeline}</label>
          <select id="bl-prop-timeline" name="timeline" class="bl-pfield">
            {p.fields.timelineOptions.map((o) => <option value={o}>{o}</option>)}
          </select>
        </div>
        <div style="grid-column:1 / -1">
          <label class="bl-plabel" for="bl-prop-location">{p.fields.location}</label>
          <input id="bl-prop-location" name="location" class="bl-pfield" />
        </div>
        <div>
          <label class="bl-plabel" for="bl-prop-name">{p.fields.name}</label>
          <input id="bl-prop-name" name="name" class="bl-pfield" required />
        </div>
        <div>
          <label class="bl-plabel" for="bl-prop-email">{p.fields.email}</label>
          <input id="bl-prop-email" name="email" type="email" class="bl-pfield" required />
        </div>
        <div style="grid-column:1 / -1">
          <label class="bl-plabel" for="bl-prop-phone">{p.fields.phone}</label>
          <input id="bl-prop-phone" name="phone" class="bl-pfield" />
        </div>
        <label style="grid-column:1 / -1;display:flex;gap:9px;align-items:flex-start;font-size:12.5px;color:var(--ink-2);line-height:1.5;margin-top:2px">
          <input type="checkbox" name="consent" required style="margin-top:3px;flex:none" />
          <span>{p.fields.consent}</span>
        </label>
        <p class="bl-err" data-prop-err style="grid-column:1 / -1;color:#ef7d80;font-size:12.5px;display:none"></p>
        <button type="submit" class="btn" style="grid-column:1 / -1;margin-top:4px">{p.submit}</button>
      </form>

      <div id="bl-prop-success" hidden style="text-align:center;padding:18px 6px">
        <div style="width:54px;height:54px;border-radius:50%;background:var(--success-soft);color:var(--success);display:grid;place-items:center;margin:0 auto;font-size:26px">&#10003;</div>
        <h4 style="font-size:18px;font-weight:800;margin-top:14px">{p.successTitle}</h4>
        <p style="font-size:14px;color:var(--ink-2);margin-top:8px;max-width:40ch;margin-inline:auto">{p.successBody}</p>
      </div>
    </div>
  </div>
</section>

<style>
  #property :global(.bl-plabel){display:block;font-size:12.5px;font-weight:600;color:var(--ink-2);margin:0 0 6px}
  #property :global(.bl-pfield){width:100%;background:var(--surface-2);border:1px solid var(--rule);border-radius:10px;color:var(--ink);font:inherit;font-size:14px;padding:10px 12px}
  #property :global(.bl-pfield:focus){outline:none;border-color:var(--accent);box-shadow:0 0 0 1px var(--accent)}
  @media (max-width: 860px){ #property :global(.bl-prop){grid-template-columns:1fr !important} }
</style>

<script is:inline define:vars={{ requiredMsg: s.business.required, emailMsg: s.business.emailInvalid }}>
  (function () {
    var form = document.getElementById("bl-prop-form");
    if (!form) return;
    var errEl = form.querySelector("[data-prop-err]");
    var success = document.getElementById("bl-prop-success");
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var req = form.querySelectorAll("[required]");
      for (var i = 0; i < req.length; i++) {
        var f = req[i];
        if (f.type === "checkbox" ? !f.checked : !String(f.value).trim()) { errEl.textContent = requiredMsg; errEl.style.display = "block"; f.focus(); return; }
        if (f.type === "email" && !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(f.value)) { errEl.textContent = emailMsg; errEl.style.display = "block"; f.focus(); return; }
      }
      form.style.display = "none";
      success.hidden = false;
    });
  })();
</script>
