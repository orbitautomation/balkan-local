---
import { type Locale, t } from "../i18n/ui";
export interface Props { lang: Locale }
const { lang } = Astro.props;
const s = t(lang);
const w = s.waitlist;
---
<section class="wrap" style="padding-block:56px;border-top:1px solid var(--rule)">
  <div class="card reveal" style="padding:40px;text-align:center;background:var(--hero-grad)">
    <p class="eyebrow" style="justify-content:center">{w.kicker}</p>
    <h2 class="section-title" style="margin-top:10px">{w.title}</h2>
    <p class="lead" style="margin:8px auto 0;text-align:center">{w.lead}</p>

    <form id="bl-wait-form" style="display:flex;gap:10px;max-width:460px;margin:22px auto 0;flex-wrap:wrap;justify-content:center">
      <input name="email" type="email" required placeholder={w.placeholder} aria-label={s.business.fields.email}
        style="flex:1;min-width:220px;background:var(--surface-2);border:1px solid var(--rule);border-radius:999px;color:var(--ink);font:inherit;font-size:15px;padding:12px 18px" />
      <button type="submit" class="btn">{w.button}</button>
    </form>
    <p id="bl-wait-err" role="alert" hidden style="color:#ef7d80;font-weight:600;font-size:13px;margin-top:12px"></p>
    <p id="bl-wait-success" hidden style="color:var(--success);font-weight:700;margin-top:14px">&#10003; {w.success}</p>
    <p style="font-size:12.5px;color:var(--ink-3);margin-top:16px">{w.appstore}</p>
  </div>
</section>

<script is:inline define:vars={{ emailMsg: s.business.emailInvalid }}>
  (function () {
    var form = document.getElementById("bl-wait-form");
    if (!form) return;
    var err = document.getElementById("bl-wait-err");
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var email = form.querySelector('[name="email"]');
      if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email.value)) {
        if (err) { err.textContent = emailMsg; err.hidden = false; }
        email.focus();
        return;
      }
      if (err) err.hidden = true;
      form.style.display = "none";
      var ok = document.getElementById("bl-wait-success");
      if (ok) ok.hidden = false;
    });
  })();
</script>
