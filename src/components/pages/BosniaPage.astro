---
/**
 * BosniaPage - /bosnia. The dedicated, premium Bosnia destination page:
 * photo hero, an interactive filterable map (cities / nature / food / mosques /
 * hidden gems) with a click-to-detail card, headline-sights and local-gems
 * grids, practical facts, why-book-through-us, a Muslim-friendly section and a
 * closing CTA. Reached from the CountrySelector (Bosnia is the only live country).
 */
import { type Locale, t, href } from "../../i18n/ui";
import PageShell from "../PageShell.astro";
import PageHero from "../PageHero.astro";
import PhotoSlot from "../PhotoSlot.astro";
import BosniaMap from "../BosniaMap.astro";
import CTASection from "../CTASection.astro";

export interface Props { lang: Locale }
const { lang } = Astro.props;
const s = t(lang);
const b = s.bosnia;

// Monoline icons for the "Live it like a local" vignettes (coffee, promenade, river).
const liveIcons = [
  '<path d="M4 8h13v4a5 5 0 0 1-5 5H9a5 5 0 0 1-5-5V8z"/><path d="M17 9h2.5a2.5 2.5 0 0 1 0 5H17"/><path d="M7 3c0 1-1 1.5-1 2.5M11 3c0 1-1 1.5-1 2.5"/>',
  '<circle cx="9" cy="5" r="2"/><path d="M9 8v6m0 0-3 6m3-6 3 6m-6-9h6"/><path d="M18 4v16"/>',
  '<path d="M3 16c2 0 2-2 4-2s2 2 4 2 2-2 4-2 2 2 4 2"/><path d="M4 12c1.5-5 4-8 8-8s6.5 3 8 8"/><path d="M3 20c2 0 2-1.5 4-1.5S9 20 11 20s2-1.5 4-1.5S17 20 19 20"/>',
];

// Monoline icons for the concierge service points (route, person, clock, edit).
const conciergeIcons = [
  '<path d="M9 6H5a2 2 0 0 0-2 2v3M15 18h4a2 2 0 0 0 2-2v-3"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="6" r="2.5"/><path d="M8.5 18H13a3 3 0 0 0 3-3V9"/>',
  '<circle cx="12" cy="8" r="3.5"/><path d="M5 20a7 7 0 0 1 14 0"/>',
  '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/>',
  '<path d="M12 20h8"/><path d="M15.5 4.5a2.1 2.1 0 0 1 3 3L8 18l-4 1 1-4z"/>',
];
---
<PageShell lang={lang} active="bosnia" meta={b.meta}>
  <PageHero
    eyebrow={b.hero.eyebrow}
    title={b.hero.title}
    lead={b.hero.lead}
    ctaLabel={b.hero.ctaPrimary}
    ctaHref={href(lang, "signup")}
  />

  <!-- Hero photo -->
  <section class="wrap" style="padding-block:0">
    <div class="reveal">
      <PhotoSlot ratio="21/9" caption={b.hero.photoCaption} eager={true} variant="hero" />
    </div>
  </section>

  <!-- Interactive map (filter + click-to-detail) -->
  <BosniaMap lang={lang} />

  <!-- Headline sights -->
  <section class="wrap" style="padding-block:64px;border-top:1px solid var(--rule)">
    <p class="eyebrow reveal">{b.touristy.kicker}</p>
    <h2 class="section-title reveal" style="margin-top:10px">{b.touristy.title}</h2>
    <p class="lead reveal" style="margin-top:10px">{b.touristy.lead}</p>
    <div class="bl-place-grid reveal" style="margin-top:28px">
      {b.touristy.items.map((it) => (
        <article class="card bl-place">
          <PhotoSlot ratio="4/3" caption={it.caption} rounded={false} variant="tone-warm" />
          <div class="bl-place-body">
            <h3 class="bl-place-name">{it.name}</h3>
            <p class="bl-place-blurb">{it.blurb}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Local / hidden gems -->
  <section class="wrap" style="padding-block:64px;border-top:1px solid var(--rule)">
    <p class="eyebrow reveal">{b.local.kicker}</p>
    <h2 class="section-title reveal" style="margin-top:10px">{b.local.title}</h2>
    <p class="lead reveal" style="margin-top:10px">{b.local.lead}</p>
    <div class="bl-place-grid reveal" style="margin-top:28px">
      {b.local.items.map((it) => (
        <article class="card bl-place">
          <PhotoSlot ratio="4/3" caption={it.caption} rounded={false} variant="tone-cool" />
          <div class="bl-place-body">
            <h3 class="bl-place-name">{it.name}</h3>
            <p class="bl-place-blurb">{it.blurb}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Live it like a local (editorial vignettes) -->
  <section class="wrap" style="padding-block:64px;border-top:1px solid var(--rule)">
    <p class="eyebrow reveal">{b.live.kicker}</p>
    <h2 class="section-title reveal" style="margin-top:10px">{b.live.title}</h2>
    <p class="lead reveal" style="margin-top:10px">{b.live.lead}</p>
    <div class="bl-live reveal" style="margin-top:28px">
      {b.live.items.map((it, i) => (
        <div class="bl-vignette">
          <span class="bl-vignette-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={liveIcons[i]} />
          </span>
          <h3 class="bl-vignette-title">{it.title}</h3>
          <p class="bl-vignette-body">{it.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Practical facts -->
  <section class="wrap" style="padding-block:64px;border-top:1px solid var(--rule)">
    <p class="eyebrow reveal">{b.facts.kicker}</p>
    <h2 class="section-title reveal" style="margin-top:10px">{b.facts.title}</h2>
    <p class="lead reveal" style="margin-top:10px">{b.facts.lead}</p>
    <div class="bl-facts reveal" style="margin-top:28px">
      {b.facts.items.map((f) => (
        <div class="card bl-fact">
          <div class="bl-fact-label">{f.label}</div>
          <p class="bl-fact-value">{f.value}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Why book through us -->
  <section class="wrap" style="padding-block:64px;border-top:1px solid var(--rule)">
    <p class="eyebrow reveal">{b.why.kicker}</p>
    <h2 class="section-title reveal" style="margin-top:10px">{b.why.title}</h2>
    <p class="lead reveal" style="margin-top:10px">{b.why.lead}</p>
    <div class="bl-why reveal" style="margin-top:28px">
      {b.why.points.map((p, i) => (
        <div class="bl-why-item">
          <span class="bl-why-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
          <div>
            <h3 class="bl-why-title">{p.title}</h3>
            <p class="bl-why-body">{p.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- We plan it for you + around-the-clock support (reassurance band) -->
  <section class="wrap" style="padding-block:64px;border-top:1px solid var(--rule)">
    <div class="card bl-concierge reveal">
      <div class="bl-concierge-head">
        <div>
          <p class="eyebrow">{b.concierge.kicker}</p>
          <h2 class="section-title" style="margin-top:10px">{b.concierge.title}</h2>
          <p class="lead" style="margin-top:10px">{b.concierge.lead}</p>
        </div>
        <span class="bl-concierge-chip">
          <span class="bl-concierge-dot" aria-hidden="true"></span>
          {b.concierge.support}
        </span>
      </div>
      <div class="bl-concierge-points">
        {b.concierge.points.map((p, i) => (
          <div class="bl-cpoint">
            <span class="bl-cpoint-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={conciergeIcons[i]} />
            </span>
            <div>
              <h3 class="bl-cpoint-title">{p.title}</h3>
              <p class="bl-cpoint-body">{p.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Muslim-friendly / halal (editorial, not the live prayer widget) -->
  <section class="wrap" style="padding-block:64px;border-top:1px solid var(--rule)">
    <p class="eyebrow reveal">{b.halal.kicker}</p>
    <h2 class="section-title reveal" style="margin-top:10px">{b.halal.title}</h2>
    <p class="lead reveal" style="margin-top:10px">{b.halal.lead}</p>
    <div class="bl-halal reveal" style="margin-top:28px">
      {b.halal.items.map((it) => (
        <div class="card bl-halal-item">
          <h3 class="bl-halal-title">{it.title}</h3>
          <p class="bl-halal-body">{it.body}</p>
        </div>
      ))}
    </div>
    <p class="reveal bl-halal-note">{b.halal.note}</p>
  </section>

  <CTASection
    title={b.cta.title}
    body={b.cta.body}
    ctaLabel={b.cta.label}
    ctaHref={href(lang, "signup")}
  />
</PageShell>

<style>
  /* Place cards (headline sights + local gems) */
  .bl-place-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .bl-place { padding: 0; overflow: hidden; }
  .bl-place-body { padding: 18px 20px 22px; }
  .bl-place-name { font-size: 16px; font-weight: 700; }
  .bl-place-blurb { font-size: 13.5px; color: var(--ink-2); line-height: 1.6; margin-top: 8px; }

  /* Live it like a local (vignettes) */
  .bl-live { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .bl-vignette { padding: 26px 24px; border-radius: var(--r-lg); border: 1px solid var(--rule); background: linear-gradient(160deg, var(--surface), transparent); }
  .bl-vignette-icon { display: inline-grid; place-items: center; width: 44px; height: 44px; border-radius: 12px; background: var(--accent-glow); color: var(--accent-2); margin-bottom: 16px; }
  .bl-vignette-title { font-size: 17px; font-weight: 700; }
  .bl-vignette-body { font-size: 13.5px; color: var(--ink-2); line-height: 1.65; margin-top: 9px; }

  /* Concierge reassurance band */
  .bl-concierge { padding: 38px 34px; background: var(--hero-grad); border-color: color-mix(in srgb, var(--accent) 30%, var(--rule)); }
  .bl-concierge-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .bl-concierge-chip { display: inline-flex; align-items: center; gap: 9px; font-size: 12.5px; font-weight: 700; color: var(--success); background: var(--success-soft); border: 1px solid color-mix(in srgb, var(--success) 30%, transparent); padding: 9px 15px; border-radius: var(--r-pill); white-space: nowrap; flex: none; }
  .bl-concierge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--success); box-shadow: 0 0 0 3px var(--success-soft); flex: none; }
  .bl-concierge-points { display: grid; grid-template-columns: 1fr 1fr; gap: 22px 30px; margin-top: 30px; }
  .bl-cpoint { display: flex; gap: 14px; align-items: flex-start; }
  .bl-cpoint-icon { display: inline-grid; place-items: center; width: 40px; height: 40px; border-radius: 11px; background: var(--accent-glow); color: var(--accent-2); flex: none; }
  .bl-cpoint-title { font-size: 15.5px; font-weight: 700; }
  .bl-cpoint-body { font-size: 13px; color: var(--ink-2); line-height: 1.6; margin-top: 5px; }

  /* Practical facts */
  .bl-facts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .bl-fact { padding: 22px 22px; }
  .bl-fact-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent-2); }
  .bl-fact-value { font-size: 14px; color: var(--ink-2); line-height: 1.6; margin-top: 10px; }

  /* Why book through us */
  .bl-why { display: grid; grid-template-columns: 1fr 1fr; gap: 26px 32px; }
  .bl-why-item { display: flex; gap: 16px; align-items: flex-start; }
  .bl-why-num { font-family: var(--font-display); font-size: 20px; font-weight: 800; color: var(--accent); line-height: 1; flex: none; padding-top: 2px; }
  .bl-why-title { font-size: 16px; font-weight: 700; }
  .bl-why-body { font-size: 13.5px; color: var(--ink-2); line-height: 1.6; margin-top: 6px; }

  /* Muslim-friendly */
  .bl-halal { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .bl-halal-item { padding: 24px 22px; }
  .bl-halal-title { font-size: 16px; font-weight: 700; }
  .bl-halal-body { font-size: 13.5px; color: var(--ink-2); line-height: 1.6; margin-top: 8px; }
  .bl-halal-note { font-size: 13px; color: var(--ink-3); margin-top: 18px; line-height: 1.6; max-width: 70ch; }

  @media (max-width: 860px) {
    .bl-place-grid, .bl-facts, .bl-halal, .bl-live { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .bl-place-grid, .bl-facts, .bl-halal, .bl-why, .bl-live, .bl-concierge-points { grid-template-columns: 1fr; }
    .bl-concierge { padding: 28px 22px; }
  }
</style>
