---
/**
 * HomePage - the consumer-first home page. Leads with the tagline, the country
 * selector and the dashboard (the central product story), then the reasons to
 * choose us, the verification standard, what you can arrange, a compact
 * Muslim-friendly callout (placed lower, as this is the English audience),
 * social proof, and the partner/property routes. Business is never the primary
 * consumer CTA.
 */
import { type Locale, t, href } from "../../i18n/ui";
import PageShell from "../PageShell.astro";
import Hero from "../Hero.astro";
import CountrySelector from "../CountrySelector.astro";
import TripDashboard from "../TripDashboard.astro";
import TrustBar from "../TrustBar.astro";
import Categories from "../Categories.astro";
import SocialProof from "../SocialProof.astro";
import CTASection from "../CTASection.astro";

export interface Props { lang: Locale }
const { lang } = Astro.props;
const s = t(lang);

// Monoline icons for the three pillars (verified, organized, local expertise).
const pillarIcons = [
  '<path d="M12 3l7 3v5c0 4.6-3 7.8-7 9-4-1.2-7-4.4-7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  '<rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/>',
  '<path d="M12 21s7-5.2 7-11a7 7 0 0 0-14 0c0 5.8 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/>',
];

const partners = [
  { ...s.teasers.business, href: href(lang, "business") },
  { ...s.teasers.property, href: href(lang, "property") },
];
---
<PageShell lang={lang} active="home">
  <Hero lang={lang} />
  <CountrySelector lang={lang} />
  <TripDashboard lang={lang} />

  <!-- Why travelers choose us -->
  <section class="wrap" style="padding-block:72px;border-top:1px solid var(--rule)">
    <p class="eyebrow reveal">{s.pillars.kicker}</p>
    <h2 class="section-title reveal" style="margin-top:10px">{s.pillars.title}</h2>
    <div class="bl-pillars reveal">
      {s.pillars.items.map((p, i) => (
        <div class="bl-pillar">
          <span class="bl-pillar-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={pillarIcons[i]} />
          </span>
          <h3 class="bl-pillar-title">{p.t}</h3>
          <p class="bl-pillar-desc">{p.d}</p>
        </div>
      ))}
    </div>
  </section>

  <TrustBar lang={lang} />
  <Categories lang={lang} />

  <!-- Muslim-friendly travel (compact, placed lower for the English audience) -->
  <section class="wrap" style="padding-block:64px;border-top:1px solid var(--rule)">
    <div class="bl-muslim reveal">
      <div>
        <p class="eyebrow">{s.muslim.kicker}</p>
        <h2 class="section-title" style="margin-top:10px">{s.muslim.title}</h2>
        <p class="lead" style="margin-top:10px">{s.muslim.lead}</p>
        <a href={`${href(lang, "experiences")}#halal`} class="btn btn-ghost" style="margin-top:20px">{s.muslim.cta}</a>
      </div>
      <span class="bl-muslim-mark" aria-hidden="true">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a9 9 0 1 0 4.5 16.8A7 7 0 0 1 17 3z"/><path d="M19 4l.6 1.6L21 6l-1.4.4L19 8l-.6-1.6L17 6l1.4-.4z"/></svg>
      </span>
    </div>
  </section>

  <SocialProof lang={lang} />

  <!-- Partner / property routes (secondary, not the consumer CTA) -->
  <section class="wrap" style="padding-block:64px;border-top:1px solid var(--rule)">
    <div class="bl-partners reveal">
      {partners.map((p) => (
        <a href={p.href} class="bl-partner">
          <h3 class="bl-partner-title">{p.title}</h3>
          <p class="bl-partner-body">{p.body}</p>
          <span class="bl-partner-cta">{p.cta} &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <CTASection
    title={s.tripDash.title}
    body={s.hero.sub}
    ctaLabel={s.hero.ctaPlan}
    ctaHref={href(lang, "destinations")}
    secondaryLabel={s.hero.ctaHow}
    secondaryHref={href(lang, "howItWorks")}
  />
</PageShell>

<style>
  .bl-pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 32px; }
  .bl-pillar-icon { display: inline-grid; place-items: center; width: 48px; height: 48px; border-radius: 14px; background: var(--accent-glow); color: var(--accent-2); margin-bottom: 18px; }
  .bl-pillar-title { font-size: 18px; font-weight: 700; }
  .bl-pillar-desc { font-size: 14.5px; color: var(--ink-2); margin-top: 8px; line-height: 1.6; }

  .bl-muslim { display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: center; }
  .bl-muslim-mark { display: grid; place-items: center; width: 96px; height: 96px; border-radius: 24px; background: var(--success-soft); color: var(--success); flex: none; }

  .bl-partners { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .bl-partner { display: block; padding: 28px; border: 1px solid var(--rule); border-radius: var(--r-lg); background: var(--surface); text-decoration: none; color: inherit; transition: border-color var(--dur) var(--ease), transform var(--dur) var(--ease); }
  .bl-partner:hover { border-color: var(--rule-hi); transform: translateY(-2px); }
  .bl-partner-title { font-size: 18px; font-weight: 700; }
  .bl-partner-body { font-size: 14px; color: var(--ink-2); margin-top: 8px; line-height: 1.6; }
  .bl-partner-cta { display: inline-block; margin-top: 14px; font-size: 13.5px; font-weight: 700; color: var(--accent-2); }

  @media (max-width: 860px) {
    .bl-pillars { grid-template-columns: 1fr; }
    .bl-partners { grid-template-columns: 1fr; }
  }
  @media (max-width: 620px) {
    .bl-muslim { grid-template-columns: 1fr; }
    .bl-muslim-mark { display: none; }
  }
</style>
