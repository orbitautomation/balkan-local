---
import { type Locale, t } from "../i18n/ui";
export interface Props { lang: Locale }
const { lang } = Astro.props;
const s = t(lang);
const b = s.business;
---
<section id="business" class="wrap" style="padding-block:56px;border-top:1px solid var(--rule)">
  <p class="eyebrow reveal">{b.kicker}</p>
  <h2 class="section-title reveal" style="margin-top:10px">{b.title}</h2>
  <p class="lead reveal" style="margin-top:8px">{b.lead}</p>

  <!-- Founding-member offer banner -->
  <div class="card reveal" style="padding:28px;margin-top:24px;background:linear-gradient(135deg, color-mix(in srgb, var(--accent) 16%, var(--surface)), var(--surface))">
    <span class="chip" style="background:var(--success-soft);border-color:transparent;color:var(--success);font-weight:700">&#9733; {b.foundingBadge}</span>
    <p style="font-size:16px;color:var(--ink);margin-top:14px;max-width:62ch;line-height:1.6">{b.foundingText}</p>
  </div>

  <!-- Why list with us -->
  <div class="bl-why reveal" style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:16px">
    {b.why.map((w) => (
      <div class="card" style="padding:20px">
        <h3 style="font-size:15px;font-weight:700;margin-bottom:5px">{w.t}</h3>
        <p style="font-size:13px;color:var(--ink-2);line-height:1.55">{w.d}</p>
      </div>
    ))}
  </div>

  <div class="bl-biz-cols reveal" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:24px;align-items:start">
    <!-- Left: how vetting works + dashboard preview -->
    <div style="display:flex;flex-direction:column;gap:16px">
      <div class="card" style="padding:24px">
        <h3 style="font-size:17px;font-weight:700">{b.vettingTitle}</h3>
        <ol style="margin-top:14px;display:flex;flex-direction:column;gap:12px;list-style:none;padding:0;counter-reset:v">
          {b.vettingSteps.map((step) => (
            <li style="display:flex;gap:12px;align-items:flex-start;counter-increment:v">
              <span style="flex:none;width:26px;height:26px;border-radius:50%;background:var(--accent);color:var(--accent-ink);font-weight:800;font-size:13px;display:grid;place-items:center" data-step></span>
              <span style="font-size:14px;color:var(--ink-2);line-height:1.5;padding-top:2px">{step}</span>
            </li>
          ))}
        </ol>
      </div>

      <!-- Dashboard preview mockup -->
      <div class="card" style="padding:20px">
        <h3 style="font-size:17px;font-weight:700;margin-bottom:12px">{b.dashTitle}</h3>
        <div style="border-radius:12px;border:1px solid var(--rule);overflow:hidden;background:var(--bg-3)">
          <div style="display:flex;gap:6px;padding:9px 12px;border-bottom:1px solid var(--rule);background:var(--surface-2)">
            <span style="width:9px;height:9px;border-radius:50%;background:#e0686b"></span>
            <span style="width:9px;height:9px;border-radius:50%;background:#e0b24b"></span>
            <span style="width:9px;height:9px;border-radius:50%;background:#5bb98c"></span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:14px">
            {b.dashItems.map((d) => (
              <div style="background:var(--surface);border:1px solid var(--rule);border-radius:10px;padding:12px">
                <div style="height:7px;width:60%;border-radius:4px;background:var(--accent);opacity:0.85"></div>
                <div style="height:22px;margin-top:9px;border-radius:6px;background:var(--surface-2)"></div>
                <div style="font-size:11px;color:var(--ink-3);margin-top:8px">{d}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Right: registration form (front-end only) -->
    <div class="card" style="padding:26px" id="bl-signup">
      <h3 style="font-size:18px;font-weight:800">{b.formTitle}</h3>
      <p id="bl-step-label" style="font-size:12.5px;color:var(--ink-3);margin-top:4px"></p>

      <form id="bl-biz-form" novalidate style="margin-top:16px;display:flex;flex-direction:column;gap:14px">
        <!-- Step 1 -->
        <div data-fstep="1" class="bl-fstep">
          <label class="bl-label" for="bl-biz-type">{b.fields.type}</label>
          <select id="bl-biz-type" name="type" class="bl-field" required>
            <option value="">--</option>
            {b.fields.typeOptions.map((o) => <option value={o}>{o}</option>)}
          </select>
          <label class="bl-label" for="bl-biz-name">{b.fields.name}</label>
          <input id="bl-biz-name" name="bizname" class="bl-field" required />
          <label class="bl-label" for="bl-biz-city">{b.fields.city}</label>
          <input id="bl-biz-city" name="city" class="bl-field" required />
        </div>
        <!-- Step 2 -->
        <div data-fstep="2" class="bl-fstep" hidden>
          <label class="bl-label" for="bl-biz-web">{b.fields.website}</label>
          <input id="bl-biz-web" name="website" class="bl-field" />
          <label class="bl-label" for="bl-biz-contact">{b.fields.contactName}</label>
          <input id="bl-biz-contact" name="contact" class="bl-field" required />
          <label class="bl-label" for="bl-biz-email">{b.fields.email}</label>
          <input id="bl-biz-email" name="email" type="email" class="bl-field" required />
        </div>
        <!-- Step 3 -->
        <div data-fstep="3" class="bl-fstep" hidden>
          <label class="bl-label" for="bl-biz-phone">{b.fields.phone}</label>
          <input id="bl-biz-phone" name="phone" class="bl-field" />
          <label class="bl-label" for="bl-biz-msg">{b.fields.message}</label>
          <textarea id="bl-biz-msg" name="message" rows="3" class="bl-field"></textarea>
        </div>

        <p class="bl-err" data-form-err style="color:#ef7d80;font-size:12.5px;display:none"></p>

        <div style="display:flex;gap:10px;margin-top:4px">
          <button type="button" class="btn btn-ghost" data-prev hidden>{b.back}</button>
          <button type="button" class="btn" data-next style="margin-inline-start:auto">{b.next}</button>
          <button type="submit" class="btn" data-submit style="margin-inline-start:auto;display:none">{b.submit}</button>
        </div>
      </form>

      <div id="bl-biz-success" hidden style="text-align:center;padding:18px 6px">
        <div style="width:54px;height:54px;border-radius:50%;background:var(--success-soft);color:var(--success);display:grid;place-items:center;margin:0 auto;font-size:26px">&#10003;</div>
        <h4 style="font-size:18px;font-weight:800;margin-top:14px">{b.successTitle}</h4>
        <p style="font-size:14px;color:var(--ink-2);margin-top:8px;max-width:38ch;margin-inline:auto">{b.successBody}</p>
      </div>
    </div>
  </div>
</section>

<style>
  #business :global(.bl-label){display:block;font-size:12.5px;font-weight:600;color:var(--ink-2);margin:12px 0 6px}
  #business :global(.bl-label:first-child){margin-top:0}
  #business :global(.bl-field){width:100%;background:var(--surface-2);border:1px solid var(--rule);border-radius:10px;color:var(--ink);font:inherit;font-size:14px;padding:10px 12px}
  #business :global(.bl-field:focus){outline:none;border-color:var(--accent);box-shadow:0 0 0 1px var(--accent)}
  @media (max-width: 860px){
    #business :global(.bl-why){grid-template-columns:1fr 1fr !important}
    #business :global(.bl-biz-cols){grid-template-columns:1fr !important}
  }
  @media (max-width: 520px){ #business :global(.bl-why){grid-template-columns:1fr !important} }
</style>

<script is:inline define:vars={{ stepWord: b.formStep, ofWord: b.formOf, requiredMsg: b.required, emailMsg: b.emailInvalid }}>
  (function () {
    var form = document.getElementById("bl-biz-form");
    if (!form) return;
    var steps = Array.prototype.slice.call(form.querySelectorAll(".bl-fstep"));
    var prevBtn = form.querySelector("[data-prev]");
    var nextBtn = form.querySelector("[data-next]");
    var subBtn = form.querySelector("[data-submit]");
    var errEl = form.querySelector("[data-form-err]");
    var label = document.getElementById("bl-step-label");
    var success = document.getElementById("bl-biz-success");
    // number the vetting steps
    document.querySelectorAll("#business [data-step]").forEach(function (el, i) { el.textContent = i + 1; });
    var cur = 0;
    function render() {
      steps.forEach(function (s, i) { s.hidden = i !== cur; });
      prevBtn.hidden = cur === 0;
      var last = cur === steps.length - 1;
      nextBtn.style.display = last ? "none" : "inline-flex";
      subBtn.style.display = last ? "inline-flex" : "none";
      label.textContent = stepWord + " " + (cur + 1) + " " + ofWord + " " + steps.length;
      errEl.style.display = "none";
    }
    function validate() {
      var bad = steps[cur].querySelectorAll("[required]");
      for (var i = 0; i < bad.length; i++) {
        if (!String(bad[i].value).trim()) { errEl.textContent = requiredMsg; errEl.style.display = "block"; bad[i].focus(); return false; }
        if (bad[i].type === "email" && !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(bad[i].value)) { errEl.textContent = emailMsg; errEl.style.display = "block"; bad[i].focus(); return false; }
      }
      return true;
    }
    nextBtn.addEventListener("click", function () { if (validate()) { cur++; render(); } });
    prevBtn.addEventListener("click", function () { cur--; render(); });
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      if (!validate()) return;
      form.style.display = "none";
      label.style.display = "none";
      success.hidden = false;
    });
    render();
  })();
</script>
